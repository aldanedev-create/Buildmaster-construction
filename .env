# Copy this file to .env and update with your values
# ============================================
# CONSTRUCTION WEBSITE SYSTEM - ENVIRONMENT VARIABLES
# ============================================

# Flask Application
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-this-to-a-random-secret-key

# Database
DATABASE_PATH=sql/construction.db
SOFT_DELETE_DAYS=30

# WhatsApp contact links and manager follow-up
WHATSAPP_ENABLED=True
WHATSAPP_BUSINESS_NUMBER=18765550123
WHATSAPP_API_TOKEN=your-token-here
WHATSAPP_PREFILL_TEXT=Hi, I'm interested in your construction services

# Gmail SMTP for contact emails, password reset, and email 2FA
SMTP_ENABLED=True
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=True
FROM_EMAIL=adminalchicken@gmail.com
FROM_NAME=BuildMaster Construction

# Admin Contacts
ADMIN_ALERT_EMAIL=aldanehutchinson5@gmail.com
ADMIN_EMAILS=admin@construction.com
ADMIN_PHONES=18765550123
ADMIN_WHATSAPP_NUMBER=18765550123

# System Settings
MAINTENANCE_MODE=False
MAINTENANCE_MESSAGE=We are making improvements and will be back shortly.
TIMEZONE=America/New_York
LOG_LEVEL=INFO

# API Settings (for mobile app integration)
API_ENABLED=True
JWT_SECRET_KEY=change-this-jwt-secret-key
